# Arquivos pessoais do usuario — NUNCA sobem pro repo publico
# Usa /pasta/* em vez de /pasta/ pra permitir re-incluir subpastas com !
/squads/*
/bases/*

# Excecao: manter os templates vazios pra quem clona
!/squads/_template-cliente/
!/squads/_template-squad/
!/bases/_template/

# Credenciais e env (mas .env.example pode ser commitado como template)
.env
.env.*
!.env.example
*.secrets
*.pem
*.key

# Arquivos locais de trabalho
*.local.md
*.draft.md
*.scratch.*

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
.cursor/

# Python (notebooklm-py etc)
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Node (vibe coding)
node_modules/
.next/
dist/
build/

# Logs
*.log
npm-debug.log*
.sync-hub-last
